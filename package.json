    "typecheck": "tsc --noEmit",
    "mcp": "tsx server/mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
