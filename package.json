{
  "name": "drawzu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "人間が図で見ているDBの姿とAIが前提にしているDBの姿を、同じ1個のモデルに揃える",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
